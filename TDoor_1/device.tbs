sub callback_http_content_arrival(byref data as string)
    
    
    if http_request_item.url = UPGRADE_URL then
          upgrade_set_buffer(data)
          dim processing as boolean=true
          dim upgrade_len as byte=len(upgrade_buffer)
          while processing
            device_firmware_upload_update()
            if len(upgrade_buffer)<>upgrade_len then
              processing=true
            else
              processing=false
            end if
            upgrade_len=len(upgrade_buffer)
          wend
    end if
                
end sub


