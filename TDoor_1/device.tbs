sub timer_t1_update()
    if timer_t1<>0 then
        'if timer_t1=0 then
        '    timer_t1=sys.timercountms+t1*1000
        'end if
        dim timercountms as dword=sys.timercountms
        if timercountms<timer_t1 then
            dim remainder as dword=timer_t1-timercountms
            remainder=remainder/1000
            if remainder=0 then
                remainder=1
            end if
            var_t1_update_completed(remainder)
        else
            var_t1_set(0)
            timer_t1=0
            
            if timer_t1_repeat then
                timer_t1=sys.timercountms+timer_t1_CURRENT_MS
                t1=timer_t1_CURRENT_MS / 1000
                if t1 = 0 AND t1 > 0 then
                    t1 = 1
                end if
            end if
        end if
        
    end if
    
end sub

