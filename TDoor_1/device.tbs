sub lcd_display_widgets(screen as byte)
dim i as byte
dim lcd_image_widget as lcd_img_widget
dim lcd_text_widget as lcd_text_widget

display_current_screen=screen

lcd.forecolor=&h1f
lcd.lock
lcd.fill(0,0,lcd.width,lcd.height)
lcd.unlock

if LCD_TEXT_WIDGETS_COUNT > 0 then
    for i = 0 to LCD_TEXT_WIDGETS_COUNT - 1
        lcd_text_widget = lcd_text_widgets(i)
        lcd_display_text_widget(lcd_text_widget)
    next i
end if

if LCD_IMG_WIDGETS_COUNT > 0 then
    for i = 0 to LCD_IMG_WIDGETS_COUNT - 1
        lcd_image_widget = lcd_img_widgets(i)
        lcd_display_img_widget(lcd_image_widget)
    next
end if
#ifdef LCD_GRAPH_WIDGETS_COUNT
if LCD_GRAPH_WIDGETS_COUNT > 0 then
    for i = 0 to LCD_GRAPH_WIDGETS_COUNT - 1
        if lcd_graph_widgets(i).screen = display_current_screen then
            lcd_graph_init(lcd_graph_widgets(i))
        end if
    next i
end if
#endif
end sub

sub lcd_display_img_widget(lcd_image_widget as lcd_img_widget)
    
    if lcd_image_widget.screen <> display_current_screen then
        exit sub
    end if
    lcd.lock
    lcd.forecolor=&h1f
    lcd.fill(lcd_image_widget.x_pos, lcd_image_widget.y_pos, lcd_image_widget.width, lcd_image_widget.height)
    if lcd_image_widget.visible<>false AND lcd_image_widget.filename <> "" then
        romfile.open(lcd_image_widget.filename)
        lcd.bmp(romfile.offset, lcd_image_widget.x_pos, lcd_image_widget.y_pos, lcd_image_widget.x_offset, lcd_image_widget.y_offset, lcd_image_widget.width, lcd_image_widget.height)
    end if
    lcd.unlock
end sub

sub lcd_display_text_widget(lcd_text_widget as lcd_text_widget)
    
    dim text_to_print as string=lcd_text_widget.text
    if lcd_text_widget.screen <> display_current_screen then
        exit sub
    end if
    lcd.forecolor=lcd_text_widget.backcolor
    lcd.lock
    lcd.fill(lcd_text_widget.x_pos, lcd_text_widget.y_pos, lcd_text_widget.width, lcd_text_widget.height)
    if lcd_text_widget.visible<>false then
        lcd.forecolor=lcd_text_widget.forecolor
        romfile.open(lcd_text_widget.font)
        lcd.setfont(romfile.offset)
        lcd.textorientation=PL_LCD_TEXT_ORIENTATION_0
        lcd.textverticalspacing=1
        lcd.texthorizontalspacing=1
        lcd.forecolor=lcd_text_widget.forecolor
        lcd.backcolor=lcd_text_widget.backcolor
        lcd.textalignment=lcd_text_widget.text_alignment
        while lcd.getprintwidth(text_to_print) > lcd_text_widget.width
            text_to_print = mid(text_to_print, 1, len(text_to_print) - 1)
        wend
        lcd.printaligned(text_to_print, lcd_text_widget.x_pos, lcd_text_widget.y_pos, lcd_text_widget.width, lcd_text_widget.height)
    end if
    lcd.unlock
end sub

sub lcd_log(text as string)
    dim i as byte
    if lcd_log_index < 29 - 1 then
        lcd_log_index = lcd_log_index + 1
    else 
        for i=0 to 29 - 2
            lcd_logs(i) = lcd_logs(i + 1)
        next i
    end if
    lcd_logs(lcd_log_index) = left(text,53)
    romfile.open(LOG_FONT_FILE)
    lcd.setfont(romfile.offset)
    lcd.lock()
    lcd.forecolor=&h1f
    lcd.fill(0,0,lcd.width,lcd.height)
    lcd.forecolor=&hffff
    for i=0 to 29 - 1
        lcd.print(lcd_logs(i),0,i * 8)
    next i
    lcd.unlock()
end sub

