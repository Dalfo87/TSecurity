sub on_firmware_update_complete(byref current_fw_upg_state as pl_upg_state_t)
    
    upload_started=false
    dim i, j as integer
    dim module_type as pl_wln_module_types

        
    if current_fw_upg_state.fw_fail_reason <> PL_FW_FAIL_NONE then
    #IFDEF RETARGET_DEBUG_PRINT
        sys.trace("There was a failure.\r\n")
    #ELSE
        sys.debugprint("There was a failure.\r\n")
    #ENDIF
    end if

    if current_fw_upg_state.state <> PL_FW_UPG_COMPLETE then
        exit sub
    end if

    pat.play("B~", PL_PAT_CANINT)

    'i = get_firmware_index(WA2000_MON)
    'if i >= 0 then
    '   upgrade_WA2000_firmware(WA2000_MON, i)
    'end if

    i = get_firmware_index(WA2000_APP)

    i =  get_firmware_index(UNCOMPRESSED_TIOS_APP)  
    if i >= 0  then 
    #IFDEF FIRMWARE_UPGRADE_FILENAME
    dim fd_status as pl_fd_status_codes
    dim iii as byte=0
    for iii=0 to 26 - 1
        filenum_release(iii)
    next iii
    fd.filenum=0
    fd.open(FIRMWARE_UPGRADE_FILENAME)
    dim checksum as dword=0
    dim s as string=""
    dim s_bytes(255) as byte
    while fd.pointer < fd.filesize
        s = fd.getdata(255)
        s_bytes=s
        for j = 0 to len(s) - 1
            checksum = checksum + s_bytes(j)
        next i
    wend
    checksum = not checksum
    checksum = checksum + 1
    if current_fw_upg_state.fw_checksums(i) <> checksum then
        sys.debugprint("The firmware update failed.")
        exit sub
    end if
    fd.copyfirmwarefromfile()
    #ELSE
    fd.copyfirmware(current_fw_upg_state.fw_lengths(i)/256+1)
    #ENDIF
    end if

    i=  get_firmware_index(COMPRESSED_TIOS_APP) 
    if i >= 0  then 
        fd.copyfirmwarelzo(YES)
    end if

    i =  get_firmware_index(UNCOMPRESSED_TIOS)  
    if i >= 0  then 
        #IFDEF FIRMWARE_UPGRADE_FILENAME
        fd.open(FIRMWARE_UPGRADE_FILENAME)
        fd.copyfirmwarefromfile()
        #ELSE
        fd.copyfirmware(current_fw_upg_state.fw_lengths(i)/256+1)
        #ENDIF
    end if

    i =  get_firmware_index(TIOS_MON)  
    if i >= 0  then 
        'fd.copymonitor()
    end if

    sys.reboot()
end sub


