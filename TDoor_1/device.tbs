function tbl_all_get_field_value(table_name_or_num as string, row_index as integer, field_name as string, byref field_value as string, raw as no_yes) as en_tbl_status_codes
    dim tmp_value as string
    dim field_type as en_tbl_field_types

    select case table_name_or_num
    
    case else:
        if tbl_is_record_deleted(row_index)=NO then
            tbl_record_sg(row_index,EN_TBL_GET)
            if raw=YES then
                tbl_field_sg_raw(field_name,field_value)
            else
                tbl_field_sg(field_name,field_value,EN_TBL_GET)
            end if
            tbl_all_get_field_value = EN_TBL_STATUS_OK
        else
            tbl_all_get_field_value = EN_TBL_STATUS_DELETED
        end if
        exit function
    end select
    if raw=YES then
        tbl_value_to_binstr(tmp_value, field_value, field_type)
    else
        field_value = tmp_value
    end if
    tbl_all_get_field_value = EN_TBL_STATUS_OK
end function
    

