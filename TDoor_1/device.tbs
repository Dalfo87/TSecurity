function tbl_static_delete_row(byref table as string, row as word) as string
    dim error as string(50)=""
    dim num_records as word
    dim shifted_value as string
    dim field_info as tbl_field_type
    dim num_fields as byte = tbl_all_get_num_fields(table)
    tbl_all_get_num_records(num_records, table, NO)
    if row> num_records then
        exit function
    end if
    if num_records=1 then
        tbl_static_set_table_size(table, 0)
        callback_tbl_modified(table, EN_TBL_MODIFIED_DELETE)
        tbl_static_delete_row="Invalid index"
        exit function
    end if
    dim i as word
    dim j as byte
    for i = row to num_records - 1
        for j = 0 to num_fields - 1
            tbl_all_get_field_info(table, j, field_info)
            tbl_all_get_field_value(table, i + 1, field_info.field_name, shifted_value, NO)
            tbl_static_set_field_value(table, i, field_info.field_name, shifted_value)
        next j
    next i
    tbl_static_set_table_size(table, num_records - 1)
    callback_tbl_modified(table, EN_TBL_MODIFIED_DELETE)
    tbl_static_delete_row=""
end function

function tbl_static_clear_table(byref table as string) as string
    tbl_static_set_table_size(table, 0)
    callback_tbl_modified(table, EN_TBL_MODIFIED_CLEAR)
end function

function tbl_static_edit_row(byref table as string, byref index as word, byref row as string) as string
dim error as string(50) = ""
    dim pos1, pos2 as word
    dim num_of_fld as byte
    dim fields(TBL_MAX_TOTAL_NUM_FIELDS) as string(128)
    dim i as byte
    dim s as string
    dim enclosed_in_quotes as no_yes=NO
    dim delimiter as string(1)="[, ]" ' placeholder; will be literal values below
    dim enclosed_quote_offset as byte=0
    dim field_info as tbl_field_type

    dim num_records as word
    tbl_all_get_num_records(num_records, table, NO)
    if index>num_records then
        tbl_static_edit_row="Invalid index"
        exit function
    end if

    if instr(1, row, chr(34), 1) = 1 and instr(len(row) - 2, row, chr(34), 1) <> 0 then
        enclosed_in_quotes=YES
        delimiter = "\x22,\x22"
        enclosed_quote_offset = 1
    else
        delimiter = ","
    end if

    num_of_fld = tbl_all_get_num_fields(table)
    pos1 = 1
    for i = 0 to num_of_fld - 1
        s = ""
        pos2 = instr(pos1 + 1, row, delimiter, 1)
        if enclosed_in_quotes=YES then
            while (instr(pos1,row,"\x5c\x22",1) > 0 and instr(pos1,row,"\x5c\x22",1) < instr(pos1 + 1,row,delimiter,1))
                or (num_of_fld = 1 and instr(pos1,row,"\x5c\x22",1) > 0)
                pos1 = pos1 + 1
                pos2=instr(pos1,row,"\x5c\x22",1)
                s = s + mid(row,pos1, pos2 - pos1) + "\x22"
                pos1 = pos2+1
                pos2=instr(pos1 + 1,row,delimiter,1)
            wend
            if pos2 = 0 then
                pos2 = len(row)
            end if
        else
            if pos2 = 0 then
                pos2 = len(row)
            end if
        end if
        s = s + mid(row,pos1+enclosed_quote_offset,pos2-pos1-enclosed_quote_offset)
        fields(i) = s
        pos1 = pos2 + 1 + enclosed_quote_offset
    next i

    for i = 0 to num_of_fld - 1
        tbl_all_get_field_info(table, i, field_info)
        tbl_static_set_field_value(table, index, field_info.field_name, fields(i))
    next i
    callback_tbl_modified(table, EN_TBL_MODIFIED_EDIT)
    tbl_static_edit_row = ""
end function

function tbl_static_add_row(byref table as string, byref row as string) as string
    dim error as string(50) = ""
    dim pos1, pos2 as word
    dim num_of_fld as byte
    dim fields(TBL_MAX_TOTAL_NUM_FIELDS) as string(128)
    dim i as byte
    dim s as string
    dim enclosed_in_quotes as no_yes=NO
    dim delimiter as string(1)=","  ' Will be set to "\x22,\x22" when quoted
    dim enclosed_quote_offset as byte=0
    dim field_info as tbl_field_type
    
    if instr(1, row, chr(34), 1) = 1 and instr(len(row) - 2, row, chr(34), 1) <> 0 then
        enclosed_in_quotes=YES
        delimiter = "\x22,\x22"
        enclosed_quote_offset = 1
    end if

    num_of_fld = tbl_all_get_num_fields(table)
    pos1 = 1
    for i = 0 to num_of_fld - 1
        s = ""
        pos2 = instr(pos1 + 1, row, delimiter, 1)
        if enclosed_in_quotes=YES then
            while (instr(pos1,row,"\x5c\x22",1) > 0 and instr(pos1,row,"\x5c\x22",1) < instr(pos1 + 1,row,delimiter,1))
                or (num_of_fld = 1 and instr(pos1,row,"\x5c\x22",1) > 0)
                pos1 = pos1 + 1
                pos2=instr(pos1,row,"\x5c\x22",1)
                s = s + mid(row,pos1, pos2 - pos1) + "\x22"
                pos1 = pos2+1
                pos2=instr(pos1 + 1,row,delimiter,1)
            wend
            if pos2 = 0 then
                pos2 = len(row)
            end if
        end if
        s = s + mid(row,pos1+enclosed_quote_offset,pos2-pos1-enclosed_quote_offset)
        fields(i) = s
        pos1 = pos2 + 1 + enclosed_quote_offset
    next i
    
    dim num_records as word
    tbl_all_get_num_records(num_records, table, NO)
    if num_records=30 then
        if tbl_static_get_table_structure(table)=EN_TBL_STRUCT_LIST then
            tbl_static_delete_row(table, 0)
            num_records = num_records - 1
        else
            tbl_static_add_row="Table is full"
            exit function
        end if
    end if

    for i = 0 to num_of_fld - 1
        tbl_all_get_field_info(table, i, field_info)
        tbl_static_set_field_value(table, num_records + 1, field_info.field_name, fields(i))
    next i
    tbl_static_set_table_size(table, num_records + 1)
    callback_tbl_modified(table, EN_TBL_MODIFIED_ADD)
    'Return empty string to indicate success
    tbl_static_add_row = ""
    
end function

' Wrapper functions to unify static vs web-backed tables

sub tbl_get_table_active_rows(byref table as string, byref tbl_rows as word, byref tbl_rows_all as word)
    if tbl_all_is_in_memory(table)=YES then
        tbl_static_get_table_active_rows(table, tbl_rows, tbl_rows_all)
    else
        tbl_web_get_table_active_rows(table, tbl_rows, tbl_rows_all)
    end if
end sub

function tbl_get_header(byref table as string) as string
    if tbl_all_is_in_memory(table)=YES then
        tbl_get_header = tbl_static_get_header(table)
    else
        tbl_get_header = tbl_web_get_header(table)
    end if
end function

function tbl_delete_row(byref table as string, row as word) as string
    if tbl_all_is_in_memory(table)=YES then
        tbl_delete_row = tbl_static_delete_row(table, row)
    else
        tbl_delete_row = tbl_web_delete_row(table, row)
    end if
end function

function tbl_clear_table(byref table as string) as string
    if tbl_all_is_in_memory(table)=YES then
        tbl_clear_table = tbl_static_clear_table(table)
    else
        tbl_clear_table = tbl_web_clear_table(table)
    end if
end function

function tbl_edit_row(byref table as string, byref index as word, byref row as string) as string
    if tbl_all_is_in_memory(table)=YES then
        tbl_edit_row = tbl_static_edit_row(table, index, row)
    else
        tbl_edit_row = tbl_web_edit_row(table, index, row)
    end if
end function

function tbl_get_row_csv(byref table as string, index as word, num_of_fld as byte) as string
    index = index - 1 + tbl_all_get_table_index_offset(table)
    if tbl_all_is_in_memory(table)=YES then
        tbl_get_row_csv = tbl_static_get_fld_data(table, index, num_of_fld)
    else
        tbl_get_row_csv = tbl_web_get_fld_data(index, num_of_fld)
    end if
end function

function tbl_get_row_json(byref table as string, index as word, num_of_fld as byte) as string
    index = index - 1 + tbl_all_get_table_index_offset(table)
    if tbl_all_is_in_memory(table)=YES then
        tbl_get_row_json = tbl_static_get_fld_data_json(table, index, num_of_fld)
    else
        tbl_get_row_json = tbl_web_get_fld_data_json(index, num_of_fld)
    end if
end function

sub tbl_static_get_table_active_rows(byref table as string, byref tbl_rows as word, byref tbl_rows_all as word)
    tbl_all_get_num_records(tbl_rows, table, NO)
    tbl_rows_all = tbl_rows
end sub

function tbl_static_get_header(byref table as string) as string
    dim num_fields as byte = tbl_all_get_num_fields(table)
    dim field_info as tbl_field_type
    dim i as byte
    dim header as string = "\x22index\x22,"
    for i = 0 to num_fields - 1
        tbl_all_get_field_info(table, i, field_info)
        header = header + "\x22" + field_info.field_name + "\x22"
        if i < num_fields - 1 then
            header = header + ","
        end if
    next i
    tbl_static_get_header = header
end function

sub tbl_get_flds(byref table as string)
    if tbl_all_is_in_memory(table)=YES then
        exit sub
    else
        tbl_web_get_flds(table)
    end if
end sub

function tbl_get_field_default(byref table as string, byref field_name as string) as string
    if tbl_all_is_in_memory(table)=YES then
        tbl_get_field_default = ""
    else
        tbl_get_field_default = tbl_web_get_field_def(table, field_name)
    end if
end function

function tbl_static_get_fld_data(table as string, row_index as word, num_of_fld as byte) as string
    dim tmp_data as string=""
    dim field_value as string
    dim i as byte
    dim num_records as word
    tbl_all_get_num_records(num_records, table, NO)
    if num_of_fld > tbl_all_get_num_fields(table) or row_index > num_records then
        tbl_static_get_fld_data=""
        exit function
    end if
    tmp_data="\x22"+str(row_index)+"\x22,"
    for i = 0 to num_of_fld - 1
        dim field_info as tbl_field_type
        tbl_all_get_field_info(table, i, field_info)
        tbl_all_get_field_value(table, row_index, field_info.field_name, field_value, NO)
        tmp_data=tmp_data+"\x22"
        tmp_data=tmp_data+field_value+"\x22"
        if i < num_of_fld - 1 then
            tmp_data=tmp_data+","
        end if
    next i
    tbl_static_get_fld_data=tmp_data
end function

function tbl_static_get_fld_data_json(table as string, row_index as word, num_of_fld as byte) as string
    dim tmp_data as string=""
    dim field_value as string
    dim i as byte
    dim num_records as word
    tbl_all_get_num_records(num_records, table, NO)
    if num_of_fld > tbl_all_get_num_fields(table) or row_index > num_records then
        tbl_static_get_fld_data_json=""
        exit function
    end if
    tmp_data="{\x22index\x22:"+str(row_index)+","
    for i = 0 to num_of_fld - 1
        dim field_info as tbl_field_type
        tbl_all_get_field_info(table, i, field_info)
        tbl_all_get_field_value(table, row_index, field_info.field_name, field_value, NO)
        tmp_data=tmp_data+"\x22"+field_info.field_name+"\x22:"
        if field_info.field_type=EN_TBL_FIELD_STRING then
            field_value="\x22"+escape_string(field_value)+"\x22"
        end if
        tmp_data=tmp_data+field_value
        if i < num_of_fld - 1 then
            tmp_data=tmp_data+","
        end if
    next i
    tmp_data=tmp_data+"}"
    tbl_static_get_fld_data_json=tmp_data
end function

function tbl_all_is_record_deleted(row_index as word, table_name_or_num as string) as no_yes
    if tbl_all_is_in_memory(table_name_or_num)=YES then
        tbl_all_is_record_deleted = NO
    else
        tbl_select(table_name_or_num, table_name_or_num)
        tbl_all_is_record_deleted = tbl_is_record_deleted(row_index)
    end if
end function

function tbl_all_get_table_info(byref table_name_or_num as string, byref table_metadata as tbl_type) as en_tbl_status_codes
    if tbl_all_is_in_memory(table_name_or_num)=YES then
        table_metadata.table_name = table_name_or_num
        table_metadata.structure = tbl_static_get_table_structure(table_name_or_num)
        table_metadata.num_of_fields = tbl_all_get_num_fields(table_name_or_num)
        tbl_all_get_table_info = EN_TBL_STATUS_OK
    else
        tbl_all_get_table_info = tbl_get_table_info(table_name_or_num, table_metadata)
    end if
end function
    

function datetime_timestamp_seconds(timestamp as dword) as float
    datetime_timestamp_seconds=datetime_timestamp_mins(timestamp) * 60 + (timestamp MOD 60)
end function

function datetime_timestamp_mins(timestamp as dword) as dword
    dim days as word = 0
    dim mins as word = 0
    dim secs as byte = 0
    dim mins_offset as integer=0
    td_get_tzone_offset(APP_TIMEZONE,mins_offset)
    datetime_from_timestamp(timestamp + mins_offset * 60, days, mins, secs)
    datetime_timestamp_mins=mins
end function

function datetime_mins_to_timestamp(mins as word) as dword
    dim datetime_days,datetime_minutes as word
    dim datetime_secs as byte
    dim timestamp as dword=datetime_current_timestamp()
    datetime_from_timestamp(timestamp,datetime_days,datetime_minutes,datetime_secs)
    datetime_minutes=mins
    td_local_to_gmt(datetime_days,datetime_minutes,APP_TIMEZONE,PL_OFF)
    datetime_mins_to_timestamp=datetime_to_timestamp(datetime_days,datetime_minutes,0)
end function


