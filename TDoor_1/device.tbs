sub var_IN1_update_completed(value as boolean)
    dim value_old as boolean = IN1
    if value < 0 then value = 0
    if value > 1 then value = 1
    IN1=value
    if value_old <> IN1 then
        #if VARIABLES_DEBUG_PRINT
            sys.debugprint("VAR> IN1 changed from " + str(value_old) + " to " + str(IN1) + "\r\n")
        #endif
    end if
end sub

