function callback_http_server_endpoint_called(byref server as http_server_state) as boolean
    callback_http_server_endpoint_called=false
    
    
    
    dim params as string=server.request_path
    dim value as string=""
    
    if server.request_method<>"GET" then
        params=server.request_value_buffer
    end if
    dim loggedin as boolean=server.request_authenticated        
    
    if server.request_file_name="api.html" then
        callback_http_server_endpoint_called=true
        dim result as string=""
        dim endpoint as string(3)=http_server_find_param(params, "e")
        dim action as string(20)=http_server_find_param(params, "action")
        dim loggedin as boolean=server.request_authenticated
    
        if endpoint="a" AND action="get" then 'authentication challenge
            http_server_response_status(200)
            http_server_response_header("Content-Type", "text/plain")
            http_server_response_header_end()
            sock.setdata("0")
            sock.send()
        else
        
        
        if loggedin then
    
        http_server_response_status(200)
        http_server_response_header("Content-Type", "application/json")
        http_server_response_header("Access-Control-Allow-Origin", "*")
        http_server_response_header("Connection", "close")
    
        http_server_response_header_end()
    
        select case endpoint
            case "i": 'information
                select case action
                    case "get":
                        dim firmwareVersion as string(40)=mid(sys.version, 2,len(sys.version) - 2)
                        dim timestamp as dword=datetime_current_timestamp()
                        dim daycount, mincount as word
                        dim seconds as byte
                        datetime_from_timestamp(timestamp, daycount, mincount, seconds)
                        sock.setdata("{")
                        sock.setdata("\x22firmwareVersion\x22:\x22" + firmwareVersion + "\x22,")
                        
                        
                                #IF PLATFORM_ID=WM2000 OR PLATFORM_ID=WS1102
                                sock.setdata("\x22ip\x22:\x22" + wln.ip + "\x22,")
                                sock.setdata("\x22mac\x22:\x22" + hex_mac(wln.mac) + "\x22,")        
                                #ELSE  
                                sock.setdata("\x22ip\x22:\x22" + net.ip + "\x22,")
                                sock.setdata("\x22mac\x22:\x22" + hex_mac(net.mac) + "\x22,")
                                #ENDIF
                                sock.setdata("\x22wlnmac\x22:\x22" + hex_mac(wln.mac) + "\x22,")
                                sock.setdata("\x22wlnip\x22:\x22" + wln.ip + "\x22,")
                        sock.setdata("\x22bootTime\x22:\x22" + lstr(timestamp - sys.timercount32 / 2)  + "\x22,")
                        #IF WLN_AVAILABLE=1
                        sock.setdata("\x22wifiOn\x22:\x22" + str(wln.enabled) + "\x22,")
                        #ELSE
                        sock.setdata("\x22wifiOn\x22:\x22false\x22,")
                        #ENDIF
                        sock.setdata("\x22timezone\x22:\x22" + str(APP_TIMEZONE) + "\x22,")
                        sock.setdata("\x22time\x22:\x22" + lstr(timestamp) + "\x22" )
                        sock.setdata("}")
                        sock.send()
                    case "edit_t":
                        dim timestamp as dword=http_server_find_param(params, "t")
                        dim days, minutes as word
                        dim secs as byte
                        datetime_from_timestamp(timestamp, days, minutes, secs)
                        td_gmt_to_local(days, minutes, datetime_tz_offset, PL_OFF)
                        #IF RTC_AVAILABLE
                        rtc.setdata(days, minutes, secs)
                        #ENDIF
                        sock.setdata("\x22time\x22:\x22" + lstr(timestamp) + "\x22")
                        sock.send()
                    case "get_tz":
                        sock.setdata(str(APP_TIMEZONE))
                        sock.send()
                    case "edit_tz":
                        dim timestamp as dword=http_server_find_param(params, "t")
                        dim days, minutes as word
                        dim secs as byte
                        dim new_tz_offset as en_td_timezones=http_server_find_param(params, "tz")
                        datetime_tz_offset= new_tz_offset
                        APP_TIMEZONE = new_tz_offset
                        datetime_from_timestamp(timestamp, days, minutes, secs)
                        td_gmt_to_local(days, minutes, new_tz_offset, PL_OFF)
                        #IF RTC_AVAILABLE
                        rtc.setdata(days, minutes, secs)
                        #ENDIF
                        sock.setdata("{")
                        sock.setdata("\x22timezone_offset\x22:\x22" + str(APP_TIMEZONE) + "\x22")
                        sock.setdata("\x22time\x22:\x22" + lstr(timestamp) + "\x22")
                        sock.setdata("}")
                        sock.send()
                    case else :
    
                end select
    
            case "v": 'variable
                dim variable as string=http_server_find_param(params, "variable")
                action=http_server_find_param(params, "action")
                value=http_server_decode(http_server_find_param(params, "value"))
                if action="get" then
                
                
                dim var_value as string = ""
                select case variable
                    
                        case "DN":
                            var_value= "\x22"+DN+"\x22"
                        case "ON":
                            var_value= "\x22"+ON+"\x22"
                        case "NETCP":
                            var_value= ftofixed(NETCP,4)
                        case "NETIP":
                            var_value= "\x22"+NETIP+"\x22"
                        case "NETNM":
                            var_value= "\x22"+NETNM+"\x22"
                        case "NETGW":
                            var_value= "\x22"+NETGW+"\x22"
                        case "stg1":
                            var_value= "\x22"+stg1+"\x22"
                        case "SCHV":
                            var_value= "\x22"+SCHV+"\x22"
                        case "IN01": var_value= "\x22"+IN01+"\x22"
                        case "IN02": var_value= "\x22"+IN02+"\x22"
                        case "IN03": var_value= "\x22"+IN03+"\x22"
                        case "IN04": var_value= "\x22"+IN04+"\x22"
                        case "IN05": var_value= "\x22"+IN05+"\x22"
                        case "IN06": var_value= "\x22"+IN06+"\x22"
                        case "IN07": var_value= "\x22"+IN07+"\x22"
                        case "IN08": var_value= "\x22"+IN08+"\x22"
                        case "OUT1": var_value= "\x22"+OUT1+"\x22"
                        case "OUT2": var_value= "\x22"+OUT2+"\x22"
                        case "OUT3": var_value= "\x22"+OUT3+"\x22"
                        case "OUT4": var_value= "\x22"+OUT4+"\x22"
                        case "OUT5": var_value= "\x22"+OUT5+"\x22"
                        case "OUT6": var_value= "\x22"+OUT6+"\x22"
                        case "MVIP": var_value= "\x22"+MVIP+"\x22"
                        case "MVPT": var_value= "\x22"+MVPT+"\x22"
                        case "MVUN": var_value= "\x22"+MVUN+"\x22"
                        case "MVPW": var_value= "\x22"+MVPW+"\x22"
                        case "XVPT": var_value= "\x22"+XVPT+"\x22"
                        case "XVCM": var_value= "\x22"+XVCM+"\x22"
                        case "XVDI": var_value= "\x22"+XVDI+"\x22"
                        case "NTPIP": var_value= "\x22"+NTPIP+"\x22"
                        case "APTP": var_value= "\x22"+APTP+"\x22"
                    case else:
                end select
                sock.setdata(var_value)
                sock.send()
                else if action="set" then


                select case variable

                        case "DN":
                            var_DN_set(value)
                        case "ON":
                            var_ON_set(value)
                        case "NETCP":
                            var_NETCP_set(string_to_float(value))
                        case "NETIP":
                            var_NETIP_set(value)
                        case "NETNM":
                            var_NETNM_set(value)
                        case "NETGW":
                            var_NETGW_set(value)
                        case "stg1":
                            var_stg1_set(value)
                        ' Nuovi settings — scrivi in EEPROM tramite stg_set
                        case "IN01","IN02","IN03","IN04","IN05","IN06","IN07","IN08":
                            stg_set(variable, 0, value)
                        case "OUT1","OUT2","OUT3","OUT4","OUT5","OUT6":
                            stg_set(variable, 0, value)
                        case "MVIP","MVPT","MVUN","MVPW","XVPT","XVCM","XVDI":
                            stg_set(variable, 0, value)
                        case "NTPIP":
                            stg_set(variable, 0, value)
                            NTPIP = value
                            SNTP_SERVER = NTPIP
                        case "APTP":
                            stg_set(variable, 0, value)
                            APTP = value
                    case else:
                end select
                end if
            case "w":
                action=http_server_find_param(params, "a")
                if action="get" then
                    dim send_timeout as dword=sys.timercountms+2000
                    sock.setdata("{")
                    
                    
                                value = "\x22DN\x22:" + "\x22"+DN+"\x22"
                    
                                value = value + ","
                    
                                
                    if sock.txfree<len(value) then
                        send_timeout=sys.timercountms+2000
                        sock.send()
                        while (sock.txlen>0) AND sys.timercountms<send_timeout
                        wend
                    end if
                    sock.setdata(value)
                    
                    
                                value = "\x22ON\x22:" + "\x22"+ON+"\x22"
                    
                                value = value + ","
                    
                                
                    if sock.txfree<len(value) then
                        send_timeout=sys.timercountms+2000
                        sock.send()
                        while (sock.txlen>0) AND sys.timercountms<send_timeout
                        wend
                    end if
                    sock.setdata(value)
                    
                    
                                value = "\x22NETCP\x22:" + ftofixed(NETCP,4)
                    
                                value = value + ","
                    
                                
                    if sock.txfree<len(value) then
                        send_timeout=sys.timercountms+2000
                        sock.send()
                        while (sock.txlen>0) AND sys.timercountms<send_timeout
                        wend
                    end if
                    sock.setdata(value)
                    
                    
                                value = "\x22NETIP\x22:" + "\x22"+NETIP+"\x22"
                    
                                value = value + ","
                    
                                
                    if sock.txfree<len(value) then
                        send_timeout=sys.timercountms+2000
                        sock.send()
                        while (sock.txlen>0) AND sys.timercountms<send_timeout
                        wend
                    end if
                    sock.setdata(value)
                    
                    
                                value = "\x22NETNM\x22:" + "\x22"+NETNM+"\x22"
                    
                                value = value + ","
                    
                                
                    if sock.txfree<len(value) then
                        send_timeout=sys.timercountms+2000
                        sock.send()
                        while (sock.txlen>0) AND sys.timercountms<send_timeout
                        wend
                    end if
                    sock.setdata(value)
                    
                    
                                value = "\x22NETGW\x22:" + "\x22"+NETGW+"\x22"
                    
                                value = value + ","
                    
                                
                    if sock.txfree<len(value) then
                        send_timeout=sys.timercountms+2000
                        sock.send()
                        while (sock.txlen>0) AND sys.timercountms<send_timeout
                        wend
                    end if
                    sock.setdata(value)
                    
                    
                                value = "\x22stg1\x22:" + "\x22"+stg1+"\x22"
                    
                                
                    if sock.txfree<len(value) then
                        send_timeout=sys.timercountms+2000
                        sock.send()
                        while (sock.txlen>0) AND sys.timercountms<send_timeout
                        wend
                    end if
                    sock.setdata(value)
                    
                    sock.setdata("}")
                    sock.send()
                    send_timeout=sys.timercountms+2000
                    while (sock.txlen>0) AND sys.timercountms<send_timeout
                    wend
                end if
            case "s": 'Settings / LUIS
                action=http_server_find_param(params, "a")
                select case action
                case "def": 'settings.xtxt and sdf.xtxt
    
                case "set": 'set value
    
                case "get": 'get value
    
                case "cmd": 'send command
                    dim cmd_str as string=http_server_decode(http_server_find_param(params, "cmd"))
                    dim x,y as byte
                    result = stgcmd_proc_cmd(cmd_str)
                    if result<>"" then
                        sock.setdata(result)
                        sock.send()
                    end if
                case else:
    
                end select
    
            case "t": 'tables
            #IFDEF TBL_MAX_NUM_TABLES
                action=http_server_find_param(params,"a")
                dim table_name as string(TBL_MAX_TABLE_NAME_LEN + 1)
                dim table_metadata as tbl_type
                dim index as byte=0
                dim row as string=""
                if action<>"get" then
                    table_name=http_server_find_param(params,"table")
                    if tbl_all_get_table_info(table_name, table_metadata) <> EN_TBL_STATUS_OK then
                        sock.setdata("Table not found")
                        sock.send()
                        exit function
                    end if
                end if
                select case action
                case "get":
                    dim table_type as string=http_server_find_param(params, "type")
                    tbl_web_get_tables(table_type)
                case "count":
                    dim tbl_rows as word=0
                    dim tbl_rows_all as word=0
                    tbl_get_table_active_rows(table_name, tbl_rows, tbl_rows_all)
                    sock.setdata(str(tbl_rows))
                    sock.send()
                case "rows":
                    server.state=HTTP_SERVER_STATE_RS_BODY_CONTENT
                    dim offset as word=val(http_server_find_param(params,"offset")) + 1
                    if offset=0 then
                        offset=1
                    end if
                    server.request_read_pos=offset
                    result=tbl_get_header(table_name)+"\r\n"
                    sock.notifysent(sock.txbuffsize-255)
                case "add":
                    row=http_server_decode(http_server_find_param(params,"row"))
                    result=tbl_all_add_row(table_name,row)
                case "delete":
                    dim row_index as word=val(http_server_decode(http_server_find_param(params,"row")))
                    result=tbl_delete_row(table_name,row_index)
                case "clear":
                    result=tbl_clear_table(table_name)
                case "edit":
                    row=http_server_decode(http_server_find_param(params,"row"))
                    dim index as word=val(http_server_find_param(params,"index"))
                    result=tbl_edit_row(table_name,index,row)
                case "get_field_default":
                    dim field_name as string=http_server_find_param(params,"field_name")
                    result=tbl_get_field_default(table_name,field_name)
                case else:
                    result="Unsupported Action"
                end select
                sock.setdata(result)
                sock.send()
            #ENDIF
    
            case "io": 'I/O stato in tempo reale
                select case action
                case "get":
                    'Restituisce stato I/O + EVST + uptime
                    'dim j already declared in this scope -- reuse it
                    dim j as byte
                    sock.setdata("{")
                    sock.setdata("\x22in\x22:[")
                    for j = 0 to NUM_INPUTS - 1
                        sock.setdata(str(in_state(j)))
                        if j < NUM_INPUTS - 1 then sock.setdata(",")
                    next j
                    sock.setdata("],")
                    sock.setdata("\x22out\x22:[")
                    for j = 0 to NUM_OUTPUTS - 1
                        if out_state(j) then
                            sock.setdata("1")
                        else
                            sock.setdata("0")
                        end if
                        if j < NUM_OUTPUTS - 1 then sock.setdata(",")
                    next j
                    sock.setdata("],\x22evst\x22:\x22" + EVST + "\x22,")
                    sock.setdata("\x22ts\x22:" + str(sys.timercountms \ 1000) + "}")
                    sock.send()

                case "set_out":
                    'Imposta un'uscita: ?e=io&action=set_out&idx=N&val=0/1
                    dim out_idx as byte = val(http_server_find_param(params, "idx"))
                    dim out_val as byte = val(http_server_find_param(params, "val"))
                    if out_idx < NUM_OUTPUTS then
                        set_output(out_idx, out_val <> 0)
                        sock.setdata("{")
                        sock.setdata("\x22ok\x22:true,")
                        sock.setdata("\x22idx\x22:" + str(out_idx) + ",")
                        if out_state(out_idx) then
                            sock.setdata("\x22val\x22:1")
                        else
                            sock.setdata("\x22val\x22:0")
                        end if
                        sock.setdata("}")
                    else
                        sock.setdata("{\x22error\x22:\x22idx fuori range\x22}")
                    end if
                    sock.send()

                case "pulse_out":
                    'Impulso 2s su un'uscita: ?e=io&action=pulse_out&idx=N
                    dim out_idx as byte = val(http_server_find_param(params, "idx"))
                    if out_idx < NUM_OUTPUTS then
                        set_output(out_idx, true)
                        pulse_end_ms(out_idx) = sys.timercountms + 2000
                        sock.setdata("{\x22ok\x22:true,\x22idx\x22:" + str(out_idx) + "}")
                    else
                        sock.setdata("{\x22error\x22:\x22idx fuori range\x22}")
                    end if
                    sock.send()

                case "set_event":
                    dim se_idx as byte
                    dim se_st as byte
                    dim se_resp as string
                    dim se_lo as byte
                    dim se_raw as boolean
                    dim se_cfg as string
                    dim se_tipo as string
                    dim se_lock as string
                    dim se_active as boolean
                    dim se_cur as byte

                    se_idx = val(http_server_find_param(params, "idx"))
                    se_st = val(http_server_find_param(params, "st"))

                    if se_idx > NUM_INPUTS - 1 then
                        se_resp = "{\x22ok\x22:0,\x22msg\x22:\x22idx fuori range\x22}"
                        goto se_send
                    end if

                    se_cur = val(mid(EVST, se_idx + 1, 1))

                    select case se_st
                    case 2:
                        mid(EVST, se_idx + 1, 1) = "2"
                        stg_set("EVST", 0, EVST)
                        log_event("SILENZIATO ingresso " + str(se_idx + 1))
                        se_resp = "{\x22ok\x22:1,\x22evst_idx\x22:2}"

                    case 0:
                        if se_cur = 3 or se_cur = 4 then
                            mid(EVST, se_idx + 1, 1) = "0"
                            stg_set("EVST", 0, EVST)
                            log_event("RIPRISTINATO ingresso " + str(se_idx + 1))
                            se_resp = "{\x22ok\x22:1,\x22evst_idx\x22:0}"
                            goto se_send
                        end if

                        se_raw = get_input_state_raw(se_idx)
                        se_cfg = get_input_config(se_idx)
                        se_tipo = get_csv_field(se_cfg, 1)
                        se_lock = get_csv_field(se_cfg, 6)

                        if se_tipo = "NC" then
                            se_active = se_raw
                        else
                            se_active = not se_raw
                        end if

                        if se_active = false or se_lock = "N" or se_lock = "" then
                            mid(EVST, se_idx + 1, 1) = "0"
                            se_lo = get_linked_output(se_idx)
                            if se_lo > 0 then set_output(se_lo - 1, false)
                            stg_set("EVST", 0, EVST)
                            log_event("CHIUSO ingresso " + str(se_idx + 1))
                            se_resp = "{\x22ok\x22:1,\x22evst_idx\x22:0}"
                        else
                            mid(EVST, se_idx + 1, 1) = "1"
                            se_lo = get_linked_output(se_idx)
                            if se_lo > 0 then set_output(se_lo - 1, true)
                            stg_set("EVST", 0, EVST)
                            log_event("ACK RESPINTO ingresso " + str(se_idx + 1))
                            se_resp = "{\x22ok\x22:0,\x22evst_idx\x22:1,\x22msg\x22:\x22input attivo\x22}"
                        end if

                    case 3:
                        mid(EVST, se_idx + 1, 1) = "3"
                        se_lo = get_linked_output(se_idx)
                        if se_lo > 0 then set_output(se_lo - 1, false)
                        stg_set("EVST", 0, EVST)
                        log_event("MANUTENZIONE ingresso " + str(se_idx + 1))
                        se_resp = "{\x22ok\x22:1,\x22evst_idx\x22:3}"

                    case 4:
                        mid(EVST, se_idx + 1, 1) = "4"
                        se_lo = get_linked_output(se_idx)
                        if se_lo > 0 then set_output(se_lo - 1, false)
                        stg_set("EVST", 0, EVST)
                        log_event("DISABILITATO ingresso " + str(se_idx + 1))
                        se_resp = "{\x22ok\x22:1,\x22evst_idx\x22:4}"

                    case else
                        se_resp = "{\x22ok\x22:0,\x22msg\x22:\x22st non valido\x22}"
                    end select

                    se_send:
                    sock.setdata(se_resp)
                    sock.send()

                case else:
                    sock.setdata("{\x22error\x22:\x22action non supportata\x22}")
                    sock.send()
                end select

            case "f": 'RPC functions
                dim variable as string=http_server_decode(http_server_find_param(params,"variable"))
                value=http_server_decode(http_server_find_param(params,"value"))


                select case variable

                    case else:
                end select
            case else:
        end select
        else
            http_server_response_status(401)
            http_server_response_header("WWW-Authenticate", "basic")
    
            http_server_response_header_end()
            sock.setdata("\x02UNAUTHORIZED\x02")
            sock.send()
        end if
        end if
    else if instr(1,server.request_file_name,"api/tables",1)>=1 then
            if loggedin then
                callback_http_server_endpoint_called=true
                server.state=HTTP_SERVER_STATE_RS_BODY_CONTENT
                dim table_name as string=http_server_find_param(params,"table")
                dim offset as word=val(http_server_find_param(params,"offset")) + 1
                if offset=0 then
                    offset=1
                end if
                server.request_read_pos=offset
    #IFDEF TBL_MAX_NUM_TABLES
                if tbl_select(table_name, table_name)<>EN_TBL_STATUS_OK then
                    http_server_response_status(500)
                    http_server_response_header("Content-Type", "application/json")
                    http_server_response_header("Access-Control-Allow-Origin", "*")
                    http_server_response_header("Connection", "close")
                    http_server_response_header_end()
                    server.state=HTTP_SERVER_STATE_END
                else
                tbl_get_flds(table_name)
    
                    http_server_response_status(200)
                    http_server_response_header("Content-Type", "application/json")
                    http_server_response_header("Access-Control-Allow-Origin", "*")
                    http_server_response_header("Connection", "close")
                    http_server_response_header_end()
                    sock.setdata("[")
                    sock.send()
                    sock.notifysent(sock.txbuffsize-255)
                end if
    #ELSE
                http_server_response_status(500)
                http_server_response_header("Content-Type", "application/json")
                http_server_response_header("Access-Control-Allow-Origin", "*")
                http_server_response_header("Connection", "close")
                http_server_response_header_end()
                server.state=HTTP_SERVER_STATE_END
    #ENDIF
            else
                http_server_response_status(401)
                http_server_response_header("WWW-Authenticate", "basic")
        
                http_server_response_header_end()
                sock.setdata("\x02UNAUTHORIZED\x02")
                sock.send()
            end if
    else
        callback_http_server_endpoint_called=false
    end if
            
end function


