const MAX_NUM_ROWS = 1

sub tbl_value_to_binstr(byref value as string, byref bin_value as string, field_type as en_tbl_field_types)
    dim w1,w2,w3,w4 as word
    select case field_type
    case EN_TBL_FIELD_BYTE:
        bin_value=chr(val(value))
    case EN_TBL_FIELD_WORD:
        w1=val(value)/256
        w2=val(value) mod 256
        bin_value=chr(w1)+chr(w2)
    case EN_TBL_FIELD_TIMESTAMP,EN_TBL_FIELD_DWORD:
        w2=lval(value)/65536
        w3=lval(value) mod 65536
        bin_value=chr(w2/256)
        bin_value=bin_value+chr(w2 mod 256)
        bin_value=bin_value+chr(w3/256)
        bin_value=bin_value+chr(w3 mod 256)
    case EN_TBL_FIELD_TIME,EN_TBL_FIELD_FLOAT:
        dim tmp_f as float=string_to_float(value)
        bintostr(bin_value,tmp_f, 4)
    case else:
        bin_value=value
    end select
end sub

function tbl_all_delete_row(byref table as string, row as word) as string
    if tbl_all_is_in_memory(table)=YES then
        tbl_static_delete_row(table, row)
    else
        tbl_web_delete_row(table, row)
    end if
end function

function tbl_sort_compare(byref a as string, byref b as string, field_type as en_tbl_field_types) as short
    dim a1 as dword=0
    dim b1 as dword=0
    dim w1,w2,w3 as word
    dim d as dword
    select case field_type
        case EN_TBL_FIELD_BYTE:
            a1=asc(a)
            b1=asc(b)
        case EN_TBL_FIELD_WORD:
            a1=asc(left(a,1))*256+asc(mid(a,2,1))
            b1=asc(left(b,1))*256+asc(mid(b,2,1))
        case EN_TBL_FIELD_DWORD,EN_TBL_FIELD_TIMESTAMP:
            w2=asc(left(a,1))*256+asc(mid(a,2,1))
            w3=asc(mid(a,3,1))*256+asc(mid(a,4,1))
            a1=w2*65536+w3
            w2=asc(left(b,1))*256+asc(mid(b,2,1))
            w3=asc(mid(b,3,1))*256+asc(mid(b,4,1))
            b1=w2*65536+w3
        end select
    select case field_type
        case EN_TBL_FIELD_BYTE,EN_TBL_FIELD_WORD,EN_TBL_FIELD_DWORD,EN_TBL_FIELD_TIMESTAMP:
            if a1>b1 then
                tbl_sort_compare=1
            else if a1=b1 then
                tbl_sort_compare=0
            else
                tbl_sort_compare=-1
            end if
        case EN_TBL_FIELD_FLOAT,EN_TBL_FIELD_TIME:
            dim a1 as float=0
            dim b1 as float=0
            strtobin(a1,a,4)
            strtobin(b1,b,4)
            if a1>b1 then
                tbl_sort_compare=1
            else if a1=b1 then
                tbl_sort_compare=0
            else
                tbl_sort_compare=-1
            end if
        case else:
            tbl_sort_compare=0
    end select
end function

function tbl_record_find_sorted(
    record_type as en_tbl_record_states,                        'If the search includes the records that are marked as deleted.
    byref search_data as string(50),                                'Searching criteria data.
    table_name as string,
    byref field_name as string(20),                                 'Searching criteria name.
    byref rec_num as word,                                      'Starting record number, also returns the first found record number
    wraparound as boolean,                                      'Wrap around
    find_method as pl_fd_find_modes) as en_tbl_status_codes     'find method (equal, greater, lesser, etc.)

    if tbl_all_is_in_memory(table_name)=NO then
        tbl_select(table_name, table_name)
        if (find_method=PL_FD_FIND_EQUAL OR find_method=PL_FD_FIND_NOT_EQUAL) then
            rec_num=rec_num+1
            tbl_record_find(record_type,search_data,field_name,rec_num,wraparound,find_method)
            exit function
        end if
    end if

    dim num_records as word=0
    dim count as word = 0

    dim search_val as string(50) = ""
    dim tmp_rec as word=0
    dim index as integer = -1
    'sort
    dim values(MAX_NUM_ROWS) as string(4)
    dim indices(MAX_NUM_ROWS) as word
    dim is_flash_table as boolean = true
    dim table_index_offset as word = 1  'Default for flash tables
    dim i as integer
    dim key as string(4)
    dim key2 as word
    dim j as integer
    i=0
    count=0

    dim ctable_info as tbl_type
    tbl_all_get_table_info(table_name, ctable_info)
    dim field_type as en_tbl_field_types=EN_TBL_FIELD_FLOAT
    dim field_metadata as tbl_field_type

    tbl_all_get_num_records(num_records,table_name,NO)
    if num_records=0 then
        rec_num=0
        exit function
    end if
    dim num_of_fld as byte = tbl_all_get_num_fields(table_name)
    for j = 0 to num_of_fld-1
        tbl_all_get_field_info(table_name,j,field_metadata)
        if field_metadata.field_name=field_name then
            field_type=field_metadata.field_type
            tbl_value_to_binstr(search_data,search_val,field_type)
            exit for
        end if
    next j
    
    ' Final safety check - if we still have no records, exit
    if num_records = 0 then
        rec_num = 0
        exit function
    end if

    if (find_method=PL_FD_FIND_EQUAL OR find_method=PL_FD_FIND_NOT_EQUAL) then
        count = 0
        i=0
        tmp_rec=-1
        while count < num_records
            if tbl_all_get_field_value(table_name,i+table_index_offset, field_name, search_val, YES)=EN_TBL_STATUS_OK then
                if find_method=PL_FD_FIND_EQUAL then
                    if search_val=search_data then
                        tmp_rec=tmp_rec+1
                    end if
                else if find_method=PL_FD_FIND_NOT_EQUAL then
                    if search_val<>search_data then
                        tmp_rec=tmp_rec+1
                    end if
                end if
                if tmp_rec=rec_num then
                    rec_num=count+1
                    exit function
                end if
                count=count+1
            end if
            i=i+1
        wend
    end if

    if ctable_info.structure=EN_TBL_STRUCT_TABLE then 
    i=0
    while count < num_records
        if tbl_all_get_field_value(table_name,i+table_index_offset, field_name, values(count), YES)=EN_TBL_STATUS_OK then
            indices(count)=i+table_index_offset
            count=count+1
        end if
        i=i+1
    wend
    
    i=0
    while i < num_records-1
        j=0
        while j < num_records - i - 1
            dim result as short=tbl_sort_compare(values(j),values(j+1),field_type)
            if result=1 then
                key=values(j)
                key2=indices(j)
                values(j)=values(j+1)
                indices(j)=indices(j+1)
                values(j+1)=key
                indices(j+1)=key2
            end if
            j=j+1
        wend
        i=i+1
    wend
    end if
    'find in array
    
    index=-1
    count=0
    dim start_i, end_i, iteration_step as integer
    start_i=0
    end_i=num_records
    iteration_step=1
    if find_method=PL_FD_FIND_LESSER OR find_method=PL_FD_FIND_LESSER_EQUAL then
        start_i=num_records-1
        end_i=-1
        iteration_step=-1
    end if
    i=start_i
    while i <> end_i and i >= 0
        dim value as string=""
        if ctable_info.structure=EN_TBL_STRUCT_TABLE then
            value=values(i)
        else
            tbl_all_get_field_value(table_name,i+1,field_name,value,YES)
        end if
        dim sort_result as short=tbl_sort_compare(value,search_val,field_type)
        dim found_index as integer=-1
        select case find_method
        case PL_FD_FIND_GREATER_EQUAL:
            if sort_result=1 OR sort_result=0 then
                found_index=i
            end if
        case PL_FD_FIND_GREATER
            if sort_result=1 then
                found_index=i
            end if
        case PL_FD_FIND_LESSER:
            if sort_result=-1 then
                found_index=i
            end if
        case PL_FD_FIND_LESSER_EQUAL:
            if sort_result=-1 OR sort_result=0 then
                found_index=i
            end if
        case PL_FD_FIND_NOT_EQUAL:
            if sort_result<>0 then
                found_index=i
            end if
        case PL_FD_FIND_EQUAL:
            if sort_result=0 then
                found_index=i
            end if
        end select
        if found_index<>-1 then
            count=count+1
            if count - 1 =rec_num then
                index=found_index
                exit while
            end if
        end if
        i=i+iteration_step
    wend
    'if found, return index
    if index <> -1 then
        if ctable_info.structure=EN_TBL_STRUCT_TABLE then
            rec_num=indices(index)
        else
            rec_num=index
        end if
    else
    'if not found and wrap around, return first sorted item
        if wraparound and num_records > 0 then
            select case find_method
            case PL_FD_FIND_GREATER_EQUAL,PL_FD_FIND_GREATER:
                if num_records > 0 then
                    rec_num=indices(0)
                else
                    rec_num=0
                end if
            case PL_FD_FIND_LESSER,PL_FD_FIND_LESSER_EQUAL:
                if num_records > 0 then
                    rec_num=indices(num_records-1)
                else
                    rec_num=0
                end if
            end select
        else
            rec_num=0
        end if
    end if
end function

sub tbl_delete_old_records(table_name as string)
    dim log_tbl_info as tbl_type
    dim dwtemp as word
    dim count as word
    dim active as word
    dim status as en_tbl_status_codes
    if tbl_all_is_in_memory(table_name)=YES then
        exit sub
    end if
    if tbl_select(table_name, table_name) = EN_TBL_STATUS_OK then
        tbl_get_table_info(table_name, log_tbl_info)
        if log_tbl_info.structure=EN_TBL_STRUCT_LIST then
            ' Trim when either file is at capacity OR active records reached max
            tbl_get_num_records(active, NO)
            if active=0 then
                exit sub
            end if
            dwtemp = log_tbl_info.maxrecs * log_tbl_info.rec_size
            count = 256/log_tbl_info.rec_size
            while ((not(fd.filesize<dwtemp)) or (active>=log_tbl_info.maxrecs)) and count>0 and active>0
                status=tbl_record_delete(1)
                if status<>EN_TBL_STATUS_OK then
                    exit while
                end if
                active=active-1
                count=count-1
            wend
        end if
    end if
end sub
        

