#IFDEF TBL_MAX_NUM_TABLES
sub tables_web_proc_sock_data_sent()
    dim index as byte=http_server_get(sock.num)
    if index<>255 then
        if http_servers(index).state=HTTP_SERVER_STATE_RS_BODY_CONTENT then
            dim server as http_server_state=http_servers(index)
            'for returning table rows
            dim tbl_rows, tbl_rows_all as word
            dim i as word
            dim j, num_of_fld as byte
            dim tmp_data as string=server.request_path
            dim is_json as boolean=instr(1,server.request_file_name,"api/tables",1)>=1
            if server.request_method<>"GET" then
                tmp_data=server.request_value_buffer
            end if
            dim table_name as string=http_server_find_param(tmp_data,"table")
            tbl_get_table_active_rows(table_name, tbl_rows, tbl_rows_all)
            num_of_fld = tbl_all_get_num_fields(table_name)
            dim row_num as word=server.request_read_pos
            dim reached_end as boolean=false
            if tbl_all_is_in_memory(table_name)=NO then
                tbl_record_read_active(row_num)
                'tbl_record_read_active wraps around if the next record is not found
                if row_num<server.request_read_pos then
                    reached_end=true
                    tbl_close(table_name)
                end if
            else
                if tbl_rows_all<server.request_read_pos then
                    reached_end=true
                end if
            end if
            dim count as word=val(http_server_find_param(tmp_data,"count"))
            dim offset as word=val(http_server_find_param(tmp_data,"offset")) + 1
            tmp_data=""
            if reached_end then
                http_servers(index).state=HTTP_SERVER_STATE_RS_BODY
                if is_json then
                    sock.setdata("]")
                    sock.send()
                end if
                sock.notifysent(0)
                exit sub
            end if
            if count=0 then
                'return all rows
                if is_json then
                    tmp_data=tbl_get_row_json(table_name, row_num, num_of_fld)
                    if server.request_read_pos<tbl_rows then
                        tmp_data=tmp_data+","
                    end if
                else
                    tmp_data=tbl_get_row_csv(table_name, row_num, num_of_fld)+"\r\n"
                end if
                sock.setdata(tmp_data)
                sock.send()
            else
                if row_num < (offset + count) then
                    if is_json then
                        tmp_data=tbl_get_row_json(table_name, row_num, num_of_fld)
                        if row_num<=tbl_rows then
                            tmp_data=tmp_data+","
                        end if
                    else
                        tmp_data=tbl_get_row_csv(table_name, row_num, num_of_fld)+"\r\n"
                    end if
                    sock.setdata(tmp_data)
                    sock.send()
                end if
            end if
            http_servers(index).request_read_pos=row_num+1
            sock.notifysent(sock.txbuffsize-len(tmp_data))
            
        end if
    end if
end sub
#ENDIF

sub callback_login_event(mode as cmd_modes)
    
end sub
            

function callback_get_timeout(mode as cmd_modes) as word

    select case mode
    case CMD_MODE_NONE:

    case CMD_MODE_UDP:
        goto get_timeout
    case else
get_timeout:
        callback_get_timeout=LOGIN_TIMEOUT
    end select

end function
            
